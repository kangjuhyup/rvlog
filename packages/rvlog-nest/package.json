    "rxjs": "^7.0.0",
    "rvlog": "^0.1.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.0",
    "@nestjs/core": "^11.1.0",
    "rxjs": "^7.8.2",
    "typescript": "^5.7.0"
  }
