{
  "name": "rvlog-nest",
  "version": "0.1.0",
  "description": "NestJS integration for rvlog",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
