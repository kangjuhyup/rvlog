{
  "name": "@kangjuhyup/rvlog-nest",
  "version": "0.1.1",
  "description": "NestJS integration for rvlog",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kangjuhyup/rvlog.git",
    "directory": "packages/rvlog-nest"
  },
  "homepage": "https://github.com/kangjuhyup/rvlog/tree/main/packages/rvlog-nest#readme",
  "bugs": {
    "url": "https://github.com/kangjuhyup/rvlog/issues"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.0.0",
    "@kangjuhyup/rvlog": "^0.1.1"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.0",
    "@nestjs/core": "^11.1.0",
    "rxjs": "^7.8.2",
    "@kangjuhyup/rvlog": "workspace:*",
    "typescript": "^5.7.0"
  }
}
