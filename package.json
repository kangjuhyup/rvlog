{
  "name": "@kangjuhyup/rvlog",
  "version": "0.1.1",
  "description": "Framework-agnostic TypeScript logging library with decorators, field masking, and error notifications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.js",
      "default": "./dist/node.js"
    }
  },
  "typesVersions": {
    "*": {
      "node": [
        "dist/node.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "test": "npm run build && vitest run",
    "test:watch": "vitest",
    "test:coverage": "npm run build && vitest run --coverage",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "changeset publish",
    "pack:check": "npm pack --dry-run",
    "pack:check:all": "npm run pack:check && npm --prefix packages/rvlog-react run pack:check && npm --prefix packages/rvlog-nest run pack:check",
    "prepublishOnly": "npm run build",
    "benchmark": "tsc --project tsconfig.benchmark.json && node dist-benchmark/benchmark/index.js",
    "example:basic": "pnpm -C example/basic dev",
    "example:express": "pnpm -C example/express dev",
    "example:nestjs": "pnpm -C example/nestjs dev",
    "example:react": "pnpm -C example/react dev",
    "example:vanilla": "pnpm -C example/vanilla dev"
  },
  "keywords": [
    "logging",
    "decorator",
    "typescript",
    "masking",
    "notification"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kangjuhyup/rvlog.git"
  },
  "homepage": "https://github.com/kangjuhyup/rvlog#readme",
  "bugs": {
    "url": "https://github.com/kangjuhyup/rvlog/issues"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "@sentry/browser": "^10.0.0"
  },
  "peerDependenciesMeta": {
    "@sentry/browser": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitest/coverage-v8": "3.2.4",
    "jsdom": "^29.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
